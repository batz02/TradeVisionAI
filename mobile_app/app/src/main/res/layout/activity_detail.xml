<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="32dp">

        <TextView
            android:id="@+id/tvDetailTicker"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary"
            android:textSize="36sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDetailName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="18sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/tvDetailPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/accent_green_bright"
            android:textSize="48sp"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:text="Caricamento..." />

        <Button
            android:id="@+id/btnSaveWatchlist"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="48dp"
            android:backgroundTint="@color/accent_green_bright"
            android:textColor="@color/text_on_accent"
            android:textStyle="bold"
            android:text="⭐ Aggiungi alla Watchlist" />

        <Button
            android:id="@+id/btnAutomatedAnalysis"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="16dp"
            android:backgroundTint="@color/btn_purple"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:text="🤖 Analisi con AI (ultimi 7 giorni)" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ultime Notizie:"
            android:textColor="@color/text_primary"
            android:textStyle="bold"
            android:layout_marginTop="32dp"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/containerNews"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="32dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnBackToSearch"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/btn_blue"
                android:textColor="@android:color/white"
                android:textStyle="bold"
                android:text="🔍 Cerca" />

            <Button
                android:id="@+id/btnBackToHome"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/bg_tertiary"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:text="🏠 Home" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>